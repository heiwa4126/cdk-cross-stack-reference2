{
	"name": "cdk-cross-stack-reference2",
	"version": "0.1.0",
	"bin": {
		"cdk-cross-stack-reference2": "bin/cdk-cross-stack-reference2.js"
	},
	"scripts": {
		"preinstall": "pnpm audit",
		"format": "oxfmt",
		"lint": "oxlint",
		"check": "oxfmt && oxlint --fix",
		"test": "jest",
		"bootstrap": ". ./.env && cdk bootstrap",
		"list": "cdk list",
		"synth": "cdk synth",
		"deploy": ". ./.env && cdk deploy --all --require-approval never",
		"diff": ". ./.env && cdk diff --all",
		"destroy": ". ./.env && cdk destroy --all",
		"build": "tsc",
		"watch": "tsc -w",
		"cdk": "cdk"
	},
	"dependencies": {
		"aws-cdk-lib": "2.245.0",
		"constructs": "^10.6.0"
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "25.5.0",
		"aws-cdk": "2.1114.1",
		"jest": "^30.3.0",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"typescript": "~6.0.2"
	}
}
